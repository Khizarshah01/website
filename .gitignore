# Dependencies
node_modules/
# package-lock.json should be committed for reproducible builds
# package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
client/.env.production

# Production builds
client/dist/
client/build/
server/dist/
server/build/

# Documents - served via API from server/uploads/documents
client/public/documents/
!client/public/documents/
client/public/documents/*
!client/public/documents/research/
!client/public/documents/research/**

# Ignore uploaded document files but keep the folder skeleton tracked
server/uploads/documents/**/*
!server/uploads/documents/**/
!server/uploads/documents/README.md
!server/uploads/documents/**/.gitkeep
!server/uploads/documents/**/README.md

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
# .vscode/ - allow .vscode/settings.json for shared editor config
.idea/
*.swp
*.swo
*~


# Server log output files
server-err.txt
server-out.txt
server/.dev-jwt-secret

# Git merge conflict backup files
*_BACKUP_*.js
*_BASE_*.js
*_LOCAL_*.js
*_REMOTE_*.js

# Testing
coverage/
.nyc_output/

# Misc
.cache/
temp/
tmp/

