PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://admin:replace_with_password@127.0.0.1:27017/CollegeWebsite?authSource=admin
MONGODB_DIRECT_URI=

# Auth secrets
JWT_SECRET=replace_with_a_unique_secret_at_least_32_characters
ADMIN_JWT_SECRET=replace_with_a_second_unique_secret_at_least_32_characters
ADMIN_GATE_TOKEN=replace_with_a_long_random_gate_token

# Cookie / browser security
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_ALLOW_INSECURE_LOOPBACK=false
AUTH_COOKIE_SAME_SITE=lax

# App behavior
ADMIN_AUTO_SEED=false
CORS_ORIGIN=https://your-domain.com
CLIENT_URL=https://your-domain.com

# Initial admin account
ADMIN_EMAIL=webteam@ssgmce.ac.in
ADMIN_PASSWORD=replace_with_a_strong_password
ADMIN_NAME=Web Team
